# =============================================================================
# .env.example — Variáveis de ambiente para OpenClaw All-in-One
# Copie para .env e preencha os valores
# =============================================================================

# ── AI Provider (ao menos um é obrigatório) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=...

# ── Autenticação da UI Web ────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=troca-esta-senha-forte

# ── Gateway token (mantenha estável entre redeploys!) ─────────────────
# Gere um valor aleatório e NÃO mude após o primeiro deploy:
# openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=gere-um-token-aqui

# ── CORS (opcional — informe seu domínio se usar proxy reverso) ───────
# OPENCLAW_ALLOWED_ORIGINS=https://openclaw.seudominio.com

# ── Porta do OpenClaw ─────────────────────────────────────────────────
PORT=8080

# ── Fuso horário ──────────────────────────────────────────────────────
TZ=America/Sao_Paulo
